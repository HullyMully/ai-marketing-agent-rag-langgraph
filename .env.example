# ============================================================
# AI Customer Assistant – environment configuration
# Copy this file to `.env` and fill in values as needed.
# NEVER commit your real .env file or any API keys.
# ============================================================

# ---- Business profile --------------------------------------
# These configure the assistant for your company. They override
# config/company.local.json and config/company.example.json.
# Sample values below are fictional and use the .example domain.
COMPANY_NAME="Acme Growth Studio"
COMPANY_DOMAIN="acme.example"
COMPANY_DESCRIPTION="Digital marketing and customer acquisition agency"
COMPANY_CONTACT_EMAIL="hello@acme.example"
DEFAULT_ASSISTANT_NAME="AI Assistant"
DEFAULT_ESCALATION_TARGET="human manager"
BUSINESS_INDUSTRY="digital marketing"

# ---- LLM configuration -------------------------------------
# Product chat is LLM-first. Keep MOCK_LLM=false for real assistant behavior.
# Set MOCK_LLM=true only for offline tests/demos without paid API keys.
MOCK_LLM=false

# OpenAI-compatible API (used when MOCK_LLM=false).
# For DeepSeek: OPENAI_BASE_URL=https://api.deepseek.com  LLM_MODEL=deepseek-chat
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---- Vector database (Qdrant) ------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=assistant_kb
# Use false with a real embedding model for production-quality RAG.
# Set true only for offline tests/demos with MOCK_LLM=true.
USE_MOCK_EMBEDDINGS=false
EMBEDDING_DIM=384

# ---- Application -------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./assistant.db
KNOWLEDGE_BASE_DIR=knowledge_base
LOG_LEVEL=INFO

# Confidence below this threshold can trigger a clarifying question.
ESCALATION_CONFIDENCE_THRESHOLD=0.45

# ---- Telegram bot (optional) -------------------------------
# Get a token from @BotFather. Keep it secret; never commit it.
TELEGRAM_BOT_TOKEN=
# Base URL of the FastAPI backend the bot talks to.
API_BASE_URL=http://localhost:8000
