# ============================================================
# NovaGrowth AI Marketing Agent – environment configuration
# Copy this file to `.env` and fill in values as needed.
# NEVER commit your real .env file. All data here is synthetic.
# ============================================================

# ---- LLM configuration -------------------------------------
# MOCK_LLM=true lets the whole project run WITHOUT any paid API key.
# Set to false to use a real OpenAI-compatible endpoint.
MOCK_LLM=true

# OpenAI-compatible API (used only when MOCK_LLM=false)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ---- Vector database (Qdrant) ------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=novagrowth_kb
# Use the deterministic local embedding fallback (no API calls).
# Recommended true for demo mode; works great with MOCK_LLM=true.
USE_MOCK_EMBEDDINGS=true
EMBEDDING_DIM=384

# ---- Application -------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./novagrowth.db
KNOWLEDGE_BASE_DIR=knowledge_base
LOG_LEVEL=INFO

# Confidence below this threshold triggers escalation to a human.
ESCALATION_CONFIDENCE_THRESHOLD=0.45

# ---- Telegram bot ------------------------------------------
# Get a token from @BotFather. Keep it secret; never commit it.
TELEGRAM_BOT_TOKEN=
# Base URL of the FastAPI backend the bot talks to.
API_BASE_URL=http://localhost:8000
